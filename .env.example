# ── Google Sheets ─────────────────────────────────────────────────────────────
# API key from Google Cloud Console (Sheets API must be enabled)
GOOGLE_SHEETS_API_KEY=

# The spreadsheet ID — found in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SHEET_ID=

# ── Resend (email service) ─────────────────────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=

# Sender address. MUST be on a domain you verified in Resend (Domains tab).
# e.g. "SoulCars <noreply@soulcars.pk>". If left blank it falls back to Resend's
# sandbox sender (onboarding@resend.dev), which ONLY delivers to the Resend
# account owner's own email — so admin mail to soulcarspakistan@gmail.com will
# NOT arrive until a verified domain is set here.
RESEND_FROM=

# ── Cloudinary (multi-image car galleries) ────────────────────────────────────
# Get all three from cloudinary.com → Settings → API Keys
# Cloud name is shown in the blue badge at the top of the API Keys page
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional — subfolder (inside the parent folder) holding the homepage hero
# slideshow images. Defaults to "Hero" if unset.
CLOUDINARY_HERO_FOLDER=

# ── Google Analytics (GA4 traffic tracking) ──────────────────────────────────
# Measurement ID from analytics.google.com → Admin → Data stream (looks like G-XXXXXXXXXX).
# Must be NEXT_PUBLIC_ (read in the browser). Analytics stays off until this is set.
NEXT_PUBLIC_GA_ID=
